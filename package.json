{
  "name": "claude-usage-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "set APP_HOST=localhost&& set PORT=3017&& set AUTO_OPEN_BROWSER=true&& next dev --hostname localhost --port 3017",
    "build": "next build",
    "start": "next start",
    "start:prod": "set APP_HOST=127.0.0.1&& set PORT=3018&& set AUTO_OPEN_BROWSER=false&& next start --hostname 127.0.0.1 --port 3018",
    "startup:install": "powershell -ExecutionPolicy Bypass -File .\\scripts\\install-startup.ps1",
    "startup:restart": "powershell -ExecutionPolicy Bypass -File .\\scripts\\restart-startup.ps1",
    "startup:uninstall": "powershell -ExecutionPolicy Bypass -File .\\scripts\\uninstall-startup.ps1",
    "lint": "eslint",
    "test": "tsx --test --test-force-exit test/*.test.ts"
  },
  "dependencies": {
    "@google-cloud/storage": "^7.10.0",
    "better-sqlite3": "^12.8.0",
    "date-fns": "^4.1.0",
    "next": "^16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
