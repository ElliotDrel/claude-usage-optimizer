# ⚠️  SECURITY: This file contains your OAuth token and GCS credentials.
# After creating the production file, run: sudo chmod 600 /etc/claude-sender.env
# Verify with: ls -l /etc/claude-sender.env
# Expected: -rw------- (not rw-r--r--)

# OAuth Authentication
# This is the API token for Claude Code (OAuth, not --bare mode).
# Never use ANTHROPIC_API_KEY or --bare mode — they bypass the Pro/Max 5-hour window
# that this app exists to manipulate.
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat-...

# Server Binding (127.0.0.1 = localhost-only, never public)
# Always bind to 127.0.0.1, never 0.0.0.0.
# Dashboard has no auth layer; rely on SSH tunnel or Tailscale for access.
HOSTNAME=127.0.0.1
PORT=3018

# Node Environment
NODE_ENV=production

# Data Directory (optional; defaults to ./data)
# DATA_DIR=/opt/claude-usage-optimizer/data

# GCS Backup Configuration
# User must create the GCS bucket and set this value.
# Backup uploads daily at 04:15 UTC.
GCS_BACKUP_BUCKET=your-gcs-bucket-name-here

# Optional: Discord Webhook URL (can also be set later via dashboard)
# Notifications are opt-in. User can set this now or add via dashboard later.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
