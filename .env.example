# Claude Usage Optimizer — environment variables
# Copy this file to .env.local and fill in what you need.
# The tracker and sender share a single env file in production (/etc/claude-usage-optimizer.env).

# ── Tracker (usage collection) ────────────────────────────────────────────────

# Option A: Claude.ai session cookie (preferred)
# Paste the full Cookie header from claude.ai DevTools.
# If it includes `lastActiveOrg`, the org endpoint is derived automatically.
CLAUDE_SESSION_COOKIE=

# Option B: OAuth bearer token (used only when CLAUDE_SESSION_COOKIE is empty)
# Auto-read from ~/.claude/.credentials.json if left blank.
CLAUDE_BEARER_TOKEN=

# Demo mode
# Dev:  leave unset (defaults to demo data) or set DEV_DEMO_MODE=false for real data
# Prod: leave unset or set false for real data; set true to force demo data
DEV_DEMO_MODE=
PROD_DEMO_MODE=

# ── Sender (anchor sends) ─────────────────────────────────────────────────────

# OAuth token for the claude CLI (from `claude setup-token`).
# Must be a Pro/Max subscription token — never use ANTHROPIC_API_KEY here.
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat-...

# ── Server binding ────────────────────────────────────────────────────────────

# Production: always bind to 127.0.0.1 (localhost only, never public).
HOSTNAME=127.0.0.1
PORT=3018

NODE_ENV=production

# ── Storage ───────────────────────────────────────────────────────────────────

# Optional: override the data directory (defaults to ./data)
# DATA_DIR=/opt/claude-usage-optimizer/data

# ── Backups ───────────────────────────────────────────────────────────────────

# GCS bucket for nightly backups (leave blank to disable)
GCS_BACKUP_BUCKET=

# ── Notifications ─────────────────────────────────────────────────────────────

# Optional Discord webhook for send-failure alerts (set via dashboard or here)
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
