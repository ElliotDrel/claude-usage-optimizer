# Claude Usage Tracker Configuration
# Copy this to .env.local and fill in your values.

# --- Auth (cookie is preferred when both are present) ---

# Option A: OAuth bearer token
# Used only when CLAUDE_SESSION_COOKIE is empty.
# Auto-read from ~/.claude/.credentials.json if left blank.
CLAUDE_BEARER_TOKEN=

# Option B: Session cookie from claude.ai browser DevTools
# Preferred by default when present.
# Copy the full Cookie header from Network tab on claude.ai
CLAUDE_SESSION_COOKIE=

# --- Endpoints ---
# Cookie auth uses CLAUDE_COOKIE_USAGE_ENDPOINT.
# Bearer auth uses CLAUDE_BEARER_USAGE_ENDPOINT.
# If you still have CLAUDE_USAGE_ENDPOINT set, it is treated as a fallback.
CLAUDE_COOKIE_USAGE_ENDPOINT=https://claude.ai/api/organizations/YOUR_ORG_ID/usage
CLAUDE_BEARER_USAGE_ENDPOINT=https://api.anthropic.com/api/oauth/usage

# Legacy single-endpoint fallback. Leave blank unless you need backward compatibility.
CLAUDE_USAGE_ENDPOINT=

# --- Server ---
PORT=3017

# --- Demo Mode ---
# Set to "true" to run the UI with fake data (no real API calls).
# Uses a separate demo.db so real data is never touched.
DEMO_MODE=false

# --- Storage ---
# Directory for SQLite database. Default: ./data
DATA_DIR=./data
