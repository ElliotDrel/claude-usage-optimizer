# Claude Usage Tracker Configuration
# Copy this to .env.local and fill in only what you need.

# Cookie auth is preferred when both auth methods are present.

# Option A: Claude.ai session cookie
# Paste the full Cookie header from claude.ai.
# If it includes `lastActiveOrg`, the app will derive the org endpoint automatically.
CLAUDE_SESSION_COOKIE=

# Option B: OAuth bearer token
# Used only when CLAUDE_SESSION_COOKIE is empty.
# Auto-read from ~/.claude/.credentials.json if left blank.
CLAUDE_BEARER_TOKEN=

# Set to true to run with fake/demo data instead of real Claude usage.
DEMO_MODE=false

